{
  "title": "Review Service Dashboard",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Total Reviews",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"expr": "sum(review_posts_total)", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Average Rating",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"expr": "avg(review_average_rating)", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Reviews per Minute",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum(rate(review_posts_total[1m])) * 60", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "API Latency (p95)",
      "gridPos": {"x": 0, "y": 10, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(review_request_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Top Products by Review Count",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "topk(5, review_count)",
          "legendFormat": "{{product_id}}",
          "refId": "A"
        }
      ]
    }
  ]
}
